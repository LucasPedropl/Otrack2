rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isAuthenticated() {
      return request.auth != null;
    }

    // Super Admins (Desenvolvedores/Donos do SaaS) - Hardcoded para Bootstrap
    function isSuperAdmin() {
      return request.auth.token.email in ['pedrolucasmota2005@gmail.com', 'pedro@gmail.com', 'teste@gmail.com'];
    }

    // Verifica se o usuário tem a role 'admin' no seu documento
    function isAdmin() {
      return isAuthenticated() && (
        isSuperAdmin() || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // --- NOVAS REGRAS DE PERMISSÃO ---

    // 1. Obras (Construction Sites) e Subcoleções
    match /construction_sites/{siteId} {
      allow read: if isAuthenticated();
      // Apenas admins podem criar/editar obras (opcional, ou deixar livre se todos puderem)
      // Para simplificar e garantir funcionamento, manteremos write para autenticados
      // Mas para "Perfis de Acesso", e configurações, restringiremos.
      allow write: if isAuthenticated();
      
      // Subcoleções de Obras
      match /tool_loans/{loanId} {
        allow read, write: if isAuthenticated();
      }
      match /rented_equipment/{equipmentId} {
        allow read, write: if isAuthenticated();
      }
      match /inventory/{itemId} {
        allow read, write: if isAuthenticated();
      }
      match /epi_withdrawals/{withdrawalId} {
        allow read, write: if isAuthenticated();
      }
      match /collaborators/{collabId} {
        allow read, write: if isAuthenticated();
      }
    }

    // 2. Estoque Global (Inventory)
    match /inventory/{itemId} {
      allow read, write: if isAuthenticated();
    }

    // 3. Colaboradores (Global)
    match /colaboradores/{collabId} {
      allow read, write: if isAuthenticated();
    }
    
    // 4. Perfis de Acesso - RESTRICTED
    match /access_profiles/{profileId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 5. Configurações (Unidades e Categorias) - RESTRICTED
    match /measurement_units/{unitId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /item_categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- REGRAS POR COLEÇÃO ---

    // 1. Empresas (Multi-tenant)
    match /companies/{companyId} {
      // Super Admins podem gerenciar empresas
      allow read, write: if isSuperAdmin();
      
      // Futuramente: Usuários da empresa podem ler dados da própria empresa
      allow read: if isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
    }

    // 2. Usuários do Sistema (Todos os usuários, incluindo admins das empresas)
    match /users/{userId} {
      // Leitura pública necessária para checagem de login/senha temporária (pesquisa por email)
      // Idealmente restrita, mas para o fluxo de "login manual" com validação de banco, precisa ser aberta ou usar Cloud Functions.
      // Vamos manter 'allow list' restrito e 'allow get' público para simplificar o login.
      allow read: if true; 

      // Super Admin pode criar/editar qualquer usuário
      allow write: if isSuperAdmin();

      // O próprio usuário pode editar seus dados (ex: mudar senha, definir nome)
      allow update: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // 3. Admins do Painel Global (Legado/Manter se necessário para o painel admin funcionar)
    match /system_admins/{email} {
      allow read, write: if isSuperAdmin();
    }
  }
}
